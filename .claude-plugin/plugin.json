{
  "name": "grasp",
  "description": "Verifies that developers understand each implementation step, without blocking delivery. Quiz or inline checkpoint modes with auto-grading via Haiku.",
  "author": {
    "name": "Matteo Ricard",
    "url": "https://github.com/matteoricard-theodo"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/setup.sh\"",
            "timeout": 10,
            "statusMessage": "Checking grasp hook setup..."
          }
        ]
      }
    ]
  }
}
